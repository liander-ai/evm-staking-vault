# Copy to .env and fill in. NEVER commit .env.
# Use a THROWAWAY key that only holds testnet funds.

# 0x-prefixed deployer/user private key
PRIVATE_KEY=0xyour_testnet_private_key

# RPC endpoint for your target chain
# Base Sepolia: https://sepolia.base.org
# BNB testnet:  https://data-seed-prebsc-1-s1.binance.org:8545
RPC_URL=https://sepolia.base.org

# Chain id: anvil 31337 | Base Sepolia 84532 | BNB testnet 97
CHAIN_ID=84532

# Filled in from the Deploy script output (see README)
VAULT=
STAKE_TOKEN=
